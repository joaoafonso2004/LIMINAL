; Engine configuration file.
config_version=5

[application]

config/name="LIMINAL"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)

[autoload]

LoadingScreen="*res://scripts/autoloads/loading_screen.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
Settings="*res://scripts/autoloads/settings.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
NetManager="*res://scripts/autoloads/net_manager.gd"
TesanaWorldEditor="*res://addons/tesana_world_editor/scene_export.gd"

[audio]

general/default_playback_type.web=1
driver/output_latency.web=100

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

