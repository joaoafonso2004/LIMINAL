[rendering]

renderer/rendering_method="gl_compatibility"
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/msaa_2d=0
limits/opengl/max_renderable_lights=64
limits/opengl/max_lights_per_object=16


textures/default_texture_filter=3
[importer_defaults]

texture={"compress/mode": 1, "compress/lossy_quality": 0.75, "compress/hdr_compression": 1, "compress/normal_map": 0, "compress/channel_pack": 0, "mipmaps/generate": false, "mipmaps/limit": -1, "roughness/mode": 0, "process/fix_alpha_border": true, "process/premult_alpha": false, "process/normal_map_invert_y": false, "process/hdr_as_srgb": false, "process/hdr_clamp_exposure": false, "process/size_limit": 1024, "detect_3d/compress_to": 1}
sample={"force/8_bit": false, "force/mono": false, "force/max_rate": true, "force/max_rate_hz": 22050, "force/max_rate_mode": 0, "edit/trim": false, "edit/normalize": false, "edit/loop_mode": 0, "edit/loop_begin": 0, "edit/loop_end": -1, "compress/mode": 1}
