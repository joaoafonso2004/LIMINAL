; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LIMINAL (4.3)"
config/version="0.2.1"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="res://assets/ui/liminal_app_icon.png"

[audio]

driver/output_latency.web=100
driver/enable_input=true

[autoload]

LoadingScreen="*res://scripts/autoloads/loading_screen.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
Settings="*res://scripts/autoloads/settings.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
NetManager="*res://scripts/autoloads/net_manager.gd"
VoiceChat="*res://scripts/autoloads/voice_chat.gd"
TesanaWorldEditor="*res://addons/tesana_world_editor/scene_export.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/lossy_quality": 0.75,
"compress/mode": 1,
"compress/normal_map": 0,
"detect_3d/compress_to": 1,
"mipmaps/generate": false,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 1024,
"roughness/mode": 0
}
sample={
"compress/mode": 1,
"edit/loop_begin": 0,
"edit/loop_end": -1,
"edit/loop_mode": 0,
"edit/normalize": false,
"edit/trim": false,
"force/8_bit": false,
"force/max_rate": true,
"force/max_rate_hz": 22050,
"force/max_rate_mode": 0,
"force/mono": false
}

